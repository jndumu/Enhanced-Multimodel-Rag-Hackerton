{
  "family": "doc-intel-rag",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::431445718054:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::431445718054:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "doc-intel-rag",
      "image": "431445718054.dkr.ecr.us-east-1.amazonaws.com/doc-intel-rag:latest",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "GLMOCR_BACKEND",          "value": "local" },
        { "name": "RERANKER_BACKEND",         "value": "cohere" },
        { "name": "MESH_LLM_MODEL",           "value": "llama3.2:1b" },
        { "name": "MESH_EMBEDDING_MODEL",     "value": "nomic-embed-text" },
        { "name": "MESH_EMBEDDING_DIM",       "value": "768" },
        { "name": "MESH_API_BASE_URL",        "value": "http://localhost:11434/v1" },
        { "name": "LOG_JSON",                 "value": "true" },
        { "name": "LOG_LEVEL",                "value": "INFO" },
        { "name": "FALLBACK_ENABLED",         "value": "true" },
        { "name": "SAFETY_PII_ENABLED",       "value": "true" },
        { "name": "ENRICHMENT_ENABLED",       "value": "true" },
        { "name": "STREAMING_ENABLED",        "value": "true" },
        { "name": "CORS_ORIGINS",             "value": "[\"*\"]" },
        { "name": "API_KEYS",                 "value": "[]" },
        { "name": "VISION_ENABLED",           "value": "false" },
        { "name": "REDIS_URL",                "value": "redis://localhost:6379" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/doc-intel-rag",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
