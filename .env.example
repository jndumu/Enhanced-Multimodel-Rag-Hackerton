# ============================================================
#  doc-intel-rag — environment variable reference
#  Copy to .env and fill in your values before running.
# ============================================================

# --- Mesh API / Requesty Gateway (REQUIRED) -----------------
# Get your key at https://app.requesty.ai
MESH_API_KEY=your-requesty-api-key-here
MESH_API_BASE_URL=https://router.requesty.ai/v1
MESH_LLM_MODEL=alibaba/qwen-turbo          # provider/model format
MESH_EMBEDDING_MODEL=openai/text-embedding-3-small
MESH_EMBEDDING_DIM=1536

# --- GLM-OCR -----------------------------------------------
GLMOCR_API_KEY=your-glmocr-api-key
GLMOCR_BACKEND=cloud           # cloud | local
GLMOCR_LOCAL_MODEL=glm-ocr:latest
GLMOCR_TIMEOUT=120

# --- Qdrant ------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                # leave blank for local dev
QDRANT_COLLECTION=doc_intel

# --- Redis -------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_EMBEDDING_TTL=86400      # seconds (1 day)
REDIS_QUERY_TTL=3600           # seconds (1 hour)

# --- Reranker (NOT Qwen/BGE/Ollama/Mesh) ------------------
RERANKER_BACKEND=cohere        # cohere | jina | openai
COHERE_API_KEY=your-cohere-api-key
COHERE_RERANK_MODEL=rerank-v3.5
JINA_API_KEY=your-jina-api-key
JINA_RERANK_MODEL=jina-reranker-v2-base-multilingual
OPENAI_API_KEY=                # Only for openai reranker path
OPENAI_RERANK_MODEL=gpt-4o-mini

# --- Tavily web fallback -----------------------------------
TAVILY_API_KEY=your-tavily-api-key
GROUNDEDNESS_THRESHOLD=0.45
TAVILY_MAX_RESULTS=5
FALLBACK_ENABLED=true

# --- Safety -----------------------------------------------
SAFETY_PII_ENABLED=true
SAFETY_INJECTION_ENABLED=true
SAFETY_OUTPUT_FAITHFULNESS=true
SAFETY_TOXICITY_ENABLED=true
SAFETY_BLOCK_ON_PII=false      # false = redact & continue

# --- Ingestion --------------------------------------------
ENRICHMENT_ENABLED=true
MAX_CHUNK_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
INGEST_BATCH_SIZE=64

# --- API --------------------------------------------------
# Comma-separated list of valid API keys
API_KEYS=key-abc123,key-def456
RATE_LIMIT_PER_MINUTE=60
STREAMING_ENABLED=true
CORS_ORIGINS=*                 # comma-separated for multiple

# --- Neo4j (optional) -------------------------------------
NEO4J_URI=                     # e.g. bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Observability ----------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true
OTEL_ENDPOINT=                 # e.g. http://jaeger:4317
OTEL_SERVICE_NAME=doc-intel-rag

# --- Test bypass (NEVER set in production) ----------------
# DOC_INTEL_SKIP_VALIDATION=1
